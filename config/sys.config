[
  {lager, [
    {colored, true},
    {handlers, [
      {lager_console_backend, [
        {level, info},
        {formatter, lager_default_formatter},
        {formatter_config, [date, " ", time, " [", severity, "] ", pid, " ", module, ":", line, " ", message, "\n"]}
      ]},
      {lager_file_backend, [
        {file, "log/arbiguard.log"},
        {level, info},
        {formatter, lager_default_formatter},
        {formatter_config, [date, " ", time, " [", severity, "] ", pid, " ", module, ":", line, " ", message, "\n"]},
        {size, 10485760},
        {date, "$D0"},
        {count, 10}
      ]},
      {lager_file_backend, [
        {file, "log/error.log"},
        {level, error},
        {formatter, lager_default_formatter},
        {formatter_config, [date, " ", time, " [", severity, "] ", pid, " ", module, ":", line, " ", message, "\n"]},
        {size, 10485760},
        {date, "$D0"},
        {count, 10}
      ]}
    ]}
  ]},

  {arbiguard, [
    %% Admin HTTP port.
    {http_port, 8771},

    %% Paper account initial capital in USDT.
    {paper_capital_usdt, 10000.0},

    %% Default scanner params. HTTP payload fields override these values.
    {default_scan, #{
      capital_usdt => 10000.0,
      max_position_pct => 0.1,
      execution_notional_usdt => 200.0,
      min_funding_rate => 0.0003,
      min_price_gap_rate => 0.002,
      max_basis_rate => 0.02,
      min_quote_volume => 0.0,
      execution_window_sec => 60.0,
      fast_refresh_sec => 1.0,
      limit => 30,
      paper_leverage => 10.0,
      min_execution_profit_usdt => 5.0,
      price_gap_close_profit_usdt => 10.0,
      execution_order_mode => <<"fok">>
    }},

    %% Runtime process intervals.
    {scanner_interval_ms, 1000},
    {funding_refresh_ms, 60000},
    {ticker_ws_enabled, true},
    {symbol_watch_enabled, true},
    {symbol_watch_interval_ms, 60000},
    {subscribe_all_tickers, true},

    %% Default exchanges. HTTP /api/funding/scan can override exchanges for that request.
    {exchanges, [
      #{
        id => <<"binance">>,
        name => <<"Binance">>,
        enabled => true,
        base_url => <<"https://fapi.binance.com">>,
        ws_host => <<"fstream.binance.com">>,
        ws_port => 443,
        ws_path => <<"/public/ws/!bookTicker">>,
        maker_fee_rate => 0.0002,
        taker_fee_rate => 0.0005,
        funding_interval_hours => 8.0,
        max_single_order_usdt => 0.0,
        max_total_position_usdt => 0.0
      },
      #{
        id => <<"okx">>,
        name => <<"OKX">>,
        enabled => true,
        base_url => <<"https://www.okx.com">>,
        ws_host => <<"ws.okx.com">>,
        ws_port => 8443,
        ws_path => <<"/ws/v5/public">>,
        maker_fee_rate => 0.0002,
        taker_fee_rate => 0.0005,
        funding_interval_hours => 8.0,
        max_single_order_usdt => 0.0,
        max_total_position_usdt => 0.0
      },
      #{
        id => <<"gate">>,
        name => <<"Gate.io">>,
        enabled => true,
        base_url => <<"https://api.gateio.ws/api/v4">>,
        ws_host => <<"fx-ws.gateio.ws">>,
        ws_port => 443,
        ws_path => <<"/v4/ws/usdt">>,
        maker_fee_rate => 0.0002,
        taker_fee_rate => 0.0005,
        funding_interval_hours => 8.0,
        max_single_order_usdt => 0.0,
        max_total_position_usdt => 0.0
      },
      #{
        id => <<"weex">>,
        name => <<"WEEX">>,
        enabled => false,
        base_url => <<"https://api-contract.weex.com">>,
        ws_host => <<"ws-contract.weex.com">>,
        ws_port => 443,
        ws_path => <<"/v3/ws/public">>,
        maker_fee_rate => 0.0002,
        taker_fee_rate => 0.0006,
        funding_interval_hours => 8.0,
        max_single_order_usdt => 0.0,
        max_total_position_usdt => 0.0
      },
      #{
        id => <<"htx">>,
        name => <<"HTX">>,
        enabled => true,
        base_url => <<"https://api.hbdm.com">>,
        ws_host => <<"api.hbdm.com">>,
        ws_port => 443,
        ws_path => <<"/linear-swap-ws">>,
        maker_fee_rate => 0.0002,
        taker_fee_rate => 0.0005,
        funding_interval_hours => 8.0,
        max_single_order_usdt => 0.0,
        max_total_position_usdt => 0.0
      }
    ]},

    %% Execution guards. arbiguard_executor and future FOK/IOC modules read these.
    {execution, #{
      max_order_book_age_ms => 1000,
      max_leg_skew_ms => 600,
      price_gap_hedge_protection_ms => 30000,
      funding_hedge_base_protection_ms => 5000,
      funding_positive_grace_ms => 2000,
      funding_negative_buffer_ms => 1500
    }}
  ]}
].
